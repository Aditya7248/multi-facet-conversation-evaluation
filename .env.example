# Copy to .env and edit as needed.
# All LLM backends in this project are open-weights and run locally —
# no third-party API providers are called.

# --- LLM backend selection ---
# One of: ollama | vllm | hf
LLM_BACKEND=ollama

# --- Ollama (default) ---
# Local LLM server. Pull the model once with `ollama pull qwen3:8b`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# --- vLLM (production-grade local inference) ---
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-8B
VLLM_API_KEY=EMPTY

# --- HuggingFace local (transformers in-process) ---
# Loads model weights directly via `transformers`. Heaviest option;
# use only when neither Ollama nor vLLM is reachable.
HF_MODEL=Qwen/Qwen3-8B
HF_DEVICE=auto

# --- Embedding model for facet routing ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Pipeline knobs (override values in configs/config.yaml) ---
RETRIEVE_TOP_K=20
SCORE_TEMPERATURE=0.0
SCORE_MAX_TOKENS=256
PARALLEL_SCORERS=4

# --- Service ports ---
API_PORT=8080
UI_PORT=8501
